{
  "name": "example-percy-detox",
  "version": "0.1.0",
  "private": true,
  "description": "Example RN + Detox todo app wired to @percy/detox for visual regression testing",
  "license": "MIT",
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "test:e2e:build:ios": "detox build --configuration ios.sim.debug",
    "test:e2e:build:android": "detox build --configuration android.emu.debug",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "smoke": "percy app:exec -- node scripts/smoke-e2e.js"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.74.5"
  },
  "devDependencies": {
    "@percy/cli": "^1.30.9",
    "@percy/detox": "^0.1.0-next.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "detox": "^20.32.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0"
  },
  "detox": {
    "test-runner": "jest"
  }
}
